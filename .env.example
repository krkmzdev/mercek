# ─── Database ───────────────────────────────────────────────
# Local dev: a hosted Postgres (Neon) with pgvector. Use the DIRECT
# (non-pooled) connection string for migrations.
# Prod (VDS): postgresql://mercek:<pw>@postgres:5432/mercek
DATABASE_URL="postgresql://user:password@host.neon.tech/mercek?sslmode=require"

# ─── LLM — separate keys per tier (spec §9.3). Prod must never boot on dev key.
GOOGLE_API_KEY_DEV=""        # free tier: Flash/Flash-Lite only, ~1500 RPD
GOOGLE_API_KEY_PROD=""       # paid tier: REQUIRED in production
ANTHROPIC_API_KEY=""         # benchmark page only
OPENAI_API_KEY=""            # benchmark page only

# ─── Storage (Cloudflare R2, S3 API) ───────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="mercek-uploads"

# ─── Auth (Better Auth, magic link) ────────────────────────
BETTER_AUTH_SECRET=""        # generate: openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000"
RESEND_API_KEY=""            # optional in dev; magic link logs to console if unset

# ─── Rate limiting (Upstash Redis) ─────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Cost guard (spec §9.4) ────────────────────────────────
MAX_DAILY_SPEND_USD="2.00"
GUEST_ANALYSES_PER_DAY="3"
AUTHED_ANALYSES_PER_DAY="10"
DEEP_ANALYSES_PER_DAY="1"

# ─── Purge (spec §6) ───────────────────────────────────────
ANALYSIS_TTL_HOURS="24"
